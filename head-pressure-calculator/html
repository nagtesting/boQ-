              <input class="inp" type="number" id="sgOv"
                     placeholder="e.g. 1.25"
                     step="0.001" oninput="onSGChange()" inputmode="decimal">
              <div class="unit-pill">SG</div>
            </div>
            <p class="hint">Entering SG auto-fills density. SG = &rho; / 1000 kg/m&sup3;.</p>
          </div>
        </div>
      </div><!-- /Custom Density -->

    </div><!-- /Left -->

    <!-- RIGHT: Results -->
    <div>

      <div class="results-panel" id="resultsPanel">
        <div class="big-readout">
          <div class="br-lbl" id="brLbl">RESULT</div>
          <div class="br-val" id="brVal">&mdash;</div>
