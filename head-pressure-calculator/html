                     min="0" max="150" value="20"
                     oninput="onTempSlider()">
              <span class="tbadge" id="tempBadge">20&deg;C</span>
            </div>
            <div style="display:grid; grid-template-columns:1fr auto; gap:6px; margin-top:4px">
              <input class="inp" type="number" id="tempInp"
                     value="20" step="1" oninput="onTempInput()" inputmode="decimal">
              <select class="sel" id="tempUnit" onchange="onTempUnitChange()" style="min-width:62px">
                <option value="C">&deg;C</option>
                <option value="F">&deg;F</option>
                <option value="K">K</option>
              </select>
            </div>
          </div>

          <!-- Fluid property chips -->
          <div class="fmeta" id="fluidMeta"></div>

          <div class="field" style="margin-top:14px">
            <label class="flbl">Gravitational Acceleration</label>
            <div class="inp-row">
              <input class="inp" type="number" id="gravInp"
                     value="9.81" step="0.001" oninput="calc()" inputmode="decimal">
              <div class="unit-pill">m/s&sup2;</div>
            </div>
            <p class="hint">Earth 9.81 &middot; Moon 1.62 &middot; Mars 3.72 &middot; Jupiter 24.79</p>
          </div>

          <button class="btn-calc" onclick="calc()">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5">
