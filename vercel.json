{
  "rewrites": [
    {
      "source": "/steam-properties-calculator",
      "destination": "/steam-properties-calculator/index.html"
    },
    {
      "source": "/cooling-tower-performance",
      "destination": "/cooling-tower-performance/index.html"
    },
    {
      "source": "/gas-equation-of-state",
      "destination": "/gas-equation-of-state/index.html"
    },
    {
      "source": "/control-valve-sizing",
      "destination": "/control-valve-sizing/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
